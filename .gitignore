# Dependency directories
node_modules/
jspm_packages/

# Build outputs
dist/
build/
out/

# Environment files - keep .env out of git
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE / Editor files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Uploads (user uploaded files - not in git)
server/uploads/*
!server/uploads/.gitkeep

# Temporary files
*.tmp
*.temp
